   "source": [
    "x = Flatten()(vgg.output)\n",
    "output = Dense(NUM_CLASSES, activation='softmax')(x)\n",
    "\n",
    "model = Model(inputs=vgg.input, outputs=output)\n",
    "model.summary()"
   ]
  },
