   "id": "a01ba134-f347-43e6-a651-f2f78b959c52",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import shutil\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import tensorflow as tf\n",
    "\n",
    "from tensorflow.keras.preprocessing.image import ImageDataGenerator\n",
    "from tensorflow.keras.applications.vgg19 import VGG19, preprocess_input\n",
    "from tensorflow.keras.layers import Dense, Flatten\n",
    "from tensorflow.keras.models import Model\n",
    "from tensorflow.keras.optimizers import Adam"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "b8bb659e-fe3a-4fa6-bbc8-58157b762f40",
   "metadata": {},
   "outputs": [],
   "source": [
    "BASE_PATH = r\"C:\\Users\\DELL\\Downloads\\DOG_BREED_PREDICTION\"\n",
    "TRAIN_DIR = os.path.join(BASE_PATH, \"train\")\n",
    "LABELS_PATH = os.path.join(BASE_PATH, \"labels.csv\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "f9ac7560-b7da-4cea-b61c-ec5d964f586c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "                                 id             breed\n",
      "0  000bec180eb18c7604dcecc8fe0dba07       boston_bull\n",
      "1  001513dfcb2ffafc82cccf4d8bbaba97             dingo\n",
      "2  001cdf01b096e06d78e9e5112d419397          pekinese\n",
      "3  00214f311d5d2247d5dfe4fe24b2303d          bluetick\n",
      "4  0021f9ceb3235effd7fcde7f7538ed62  golden_retriever\n"
     ]
    }
   ],
   "source": [
    "labels = pd.read_csv(LABELS_PATH)\n",
    "print(labels.head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "e890198c-3f3a-42ec-809a-0a4a7a578c39",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Subset created with 20 breeds\n"
     ]
    }
   ],
   "source": [
    "SUBSET_TRAIN = os.path.join(BASE_PATH, \"subset\", \"train\")\n",
    "os.makedirs(SUBSET_TRAIN, exist_ok=True)\n",
    "\n",
    "breeds = labels['breed'].unique()[:20]\n",
    "\n",
    "for breed in breeds:\n",
    "    breed_folder = os.path.join(SUBSET_TRAIN, breed)\n",
    "    os.makedirs(breed_folder, exist_ok=True)\n",
    "\n",
    "    image_ids = labels[labels['breed'] == breed]['id']\n",
    "\n",
    "    for img_id in image_ids:\n",
    "        src = os.path.join(TRAIN_DIR, img_id + \".jpg\")\n",
    "        dst = os.path.join(breed_folder, img_id + \".jpg\")\n",
    "\n",
    "        if os.path.exists(src):\n",
    "            shutil.copy(src, dst)\n",
    "\n",
    "print(\"✅ Subset created with 20 breeds\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "4bc15388-b7e8-404b-b65f-e5bdd0cd8e84",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Found 1364 images belonging to 20 classes.\n",
      "Found 332 images belonging to 20 classes.\n",
      "Classes: 20\n"
     ]
    }
   ],
   "source": [
    "IMAGE_SIZE = (224, 224)\n",
    "BATCH_SIZE = 32\n",
    "\n",
    "train_datagen = ImageDataGenerator(\n",
    "    preprocessing_function=preprocess_input,\n",
    "    validation_split=0.2\n",
    ")\n",
    "\n",
    "train_generator = train_datagen.flow_from_directory(\n",
    "    SUBSET_TRAIN,\n",
    "    target_size=IMAGE_SIZE,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    class_mode='categorical',\n",
    "    subset='training'\n",
    ")\n",
    "\n",
    "val_generator = train_datagen.flow_from_directory(\n",
    "    SUBSET_TRAIN,\n",
    "    target_size=IMAGE_SIZE,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    class_mode='categorical',\n",
    "    subset='validation'\n",
    ")\n",
    "\n",
    "NUM_CLASSES = train_generator.num_classes\n",
    "print(\"Classes:\", NUM_CLASSES)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "7bb0bc73-01bb-4357-88ad-f4a22898698e",
   "metadata": {},
   "outputs": [],
   "source": [
    "vgg = VGG19(\n",
    "    input_shape=IMAGE_SIZE + (3,),\n",
    "    weights='imagenet',\n",
    "    include_top=False\n",
    ")\n",
    "\n",
    "for layer in vgg.layers:\n",
    "    layer.trainable = False"
   ]
  },
